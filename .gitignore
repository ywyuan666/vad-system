# VAD 系统 .gitignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# 虚拟环境
venv/
.venv/
env/

# 模型 / 数据
checkpoints/
*.pt
*.pth
*.onnx
data/dataset/
data/raw/
data/processed/

# 结果
results/
*.wav
*.mp3
*.flac

# 分析报告
analysis/
!analysis/.gitkeep

# 生成的文档（构建产物）

# IDE
.vscode/
.idea/
*.swp
*.swo

# 系统
.DS_Store
Thumbs.db

# 日志
*.log
wandb/

# 代码质量
.ruff_cache/
.mypy_cache/

# 测试中间输出
test_out*.txt
test_err*.txt
.pytest_cache/
